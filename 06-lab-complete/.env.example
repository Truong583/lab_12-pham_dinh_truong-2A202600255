# =========================================================
# 📝 Template cấu hình cho Production AI Agent (Day 12 Lab)
# =========================================================
# Copy file này thành .env.local và điền giá trị thật.
# ❌ KHÔNG commit file .env.local chứa giá trị thật lên Git.

# 🌐 Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true

# 🤖 App Information
APP_NAME="Production AI Agent"
APP_VERSION=1.0.0

# 🧠 LLM (OpenAI)
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# 🔒 Security (BẮT BUỘC thay đổi khi chạy Production)
AGENT_API_KEY=13Aa@2005
JWT_SECRET=super-secret-key-for-jwt-tokens-vinuni
ALLOWED_ORIGINS=*

# ⚡ Rate Limiting
RATE_LIMIT_PER_MINUTE=20

# 💰 Budget Guard
DAILY_BUDGET_USD=5.0

# 🗄️ Storage (Redis)
# Sử dụng 'redis://localhost:6379/0' cho Local Docker
# Sử dụng giá trị từ Railway/Render cho Production
REDIS_URL=redis://localhost:6379/0
